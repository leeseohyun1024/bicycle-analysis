    년월 TEXT        NOT NULL,   -- '202507'
    지점 TEXT        NOT NULL,   -- '108'
    평균기온 REAL,
    평균최저기온 REAL,
    평균최고기온 REAL,
    PRIMARY KEY (년월, 지점)
);

CREATE TABLE 강수량(
    년월 TEXT        NOT NULL,   -- '202507'
    지점 TEXT        NOT NULL,   -- '108'
    강수량 REAL,
    PRIMARY KEY (년월, 지점)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
